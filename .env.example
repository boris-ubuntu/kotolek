# Kotolek Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Database Configuration
POSTGRES_USER=kotolek
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=kotolek

# Alternative: Full database URL (takes precedence over individual settings)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Database Connection (for Docker Compose internal networking)
DB_HOST=db
DB_PORT=5432

# Security - REQUIRED in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_very_long_random_secret_key_here_min_32_chars

# Debug Mode - Set to False in production!
DEBUG=False

# CORS Origins (comma-separated) - Optional
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com